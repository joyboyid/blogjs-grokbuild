# =====================================================
# BlogJS Environment Configuration
# Copy this file to .env and fill in your values
# =====================================================

# Server
PORT=3000
NODE_ENV=development

# Database - MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sss
DB_NAME=sss

# Session Secret (use a long random string in production!)
SESSION_SECRET=themysecretkeyismarleenlevian    

# Upload path (relative to public)
UPLOAD_DIR=uploads

# Admin default (optional reference)
# After first run, please change the default admin password
DEFAULT_ADMIN_EMAIL=admin@blogjs.local
DEFAULT_ADMIN_PASSWORD=admin123
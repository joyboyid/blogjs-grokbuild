<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    
    <!-- Quill.js - Free Rich Text Editor (no API key required) -->
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/admin/dashboard">BlogJS Admin</a>
            <div>
                <a href="/" class="btn btn-outline-light btn-sm me-2" target="_blank">View Site</a>
                <a href="/auth/logout" class="btn btn-danger btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2 px-0 bg-light border-end min-vh-100">
                <div class="list-group list-group-flush">
                    <a href="/admin/dashboard" class="list-group-item list-group-item-action">📊 Dashboard</a>
                    <a href="/admin/posts" class="list-group-item list-group-item-action active">📝 Posts</a>
                    <a href="/admin/categories" class="list-group-item list-group-item-action">📁 Categories</a>
                </div>
            </div>

            <div class="col-md-10 p-4">
                <%- include('../partials/flash') %>

                <div class="d-flex justify-content-between mb-3">
                    <h2><%= post ? 'Edit Post' : 'Create New Post' %></h2>
                    <a href="/admin/posts" class="btn btn-outline-secondary">← Back to Posts</a>
                </div>

                <% if (errors && errors.length > 0) { %>
                    <div class="alert alert-danger">
                        <% errors.forEach(e => { %><div><%= e.msg %></div><% }) %>
                    </div>
                <% } %>

                <form action="<%= post ? '/admin/posts/' + post.id + '/update' : '/admin/posts/create' %>" 
                      method="POST" enctype="multipart/form-data" novalidate>
                    
                    <div class="row">
                        <div class="col-lg-8">
                            <!-- Title -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Post Title *</label>
                                <input type="text" name="title" class="form-control form-control-lg" 
                                       value="<%= oldInput.title || (post ? post.title : '') %>" required>
                            </div>

                            <!-- Rich Text Editor (Quill.js) -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Content *</label>
                                
                                <!-- Quill Editor Container -->
                                <div id="quill-editor" style="height: 420px; background: white; border-radius: 6px;"></div>
                                
                                <!-- Hidden textarea for form submission -->
                                <textarea name="content" id="content" style="display: none;"></textarea>
                                
                                <!-- Safe container for initial content (used only for editing) -->
                                <script id="initial-quill-content" type="application/json"><%- JSON.stringify(oldInput.content || (post ? post.content : '')) %></script>
                            </div>
                        </div>

                        <div class="col-lg-4">
                            <!-- Featured Image -->
                            <div class="card mb-3">
                                <div class="card-header">Featured Image</div>
                                <div class="card-body">
                                    <% if (post && post.featured_image) { %>
                                        <img src="<%= post.featured_image %>" class="img-fluid rounded mb-2" style="max-height:140px">
                                        <div class="small text-muted mb-2">Current image. Upload new to replace.</div>
                                    <% } %>
                                    <input type="file" name="featured_image" class="form-control" accept="image/*">
                                    <div class="form-text">Max 5MB. JPG, PNG, GIF, WEBP</div>
                                </div>
                            </div>

                            <!-- Category -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Category</label>
                                <select name="category_id" class="form-select">
                                    <option value="">— Uncategorized —</option>
                                    <% categories.forEach(cat => { %>
                                        <option value="<%= cat.id %>" 
                                            <%= (oldInput.category_id == cat.id) || (post && post.category_id == cat.id) ? 'selected' : '' %>>
                                            <%= cat.name %>
                                        </option>
                                    <% }) %>
                                </select>
                            </div>

                            <!-- Tags -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Tags</label>
                                <input type="text" name="tags" class="form-control" 
                                       placeholder="nodejs, express, tutorial" 
                                       value="<%= oldInput.tags || (post ? post.tags : '') %>">
                                <div class="form-text">Comma separated</div>
                            </div>

                            <div class="d-grid gap-2 mt-4">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <%= post ? 'Update Post' : 'Publish Post' %>
                                </button>
                                <a href="/admin/posts" class="btn btn-light">Cancel</a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Quill.js -->
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    
    <script>
        // =====================================================
        // Quill.js Rich Text Editor Initialization
        // Free, no API key, no registration required
        // =====================================================
        const quill = new Quill('#quill-editor', {
            theme: 'snow',
            placeholder: 'Tulis konten post di sini...',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ 'color': [] }, { 'background': [] }],
                    [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                    [{ 'align': [] }],
                    ['link', 'blockquote', 'code-block'],
                    ['clean']
                ]
            }
        });

        // Load existing content safely when editing (using JSON script tag)
        const initialScript = document.getElementById('initial-quill-content');
        if (initialScript) {
            try {
                const initialHTML = JSON.parse(initialScript.textContent || '""');
                if (initialHTML && initialHTML.trim() !== '') {
                    quill.clipboard.dangerouslyPasteHTML(initialHTML);
                }
            } catch (err) {
                console.warn('Failed to load initial Quill content', err);
            }
        }

        // On form submit: copy Quill content to hidden field + validate
        const form = document.querySelector('form');
        form.addEventListener('submit', function (e) {
            const contentTextarea = document.getElementById('content');
            const htmlContent = quill.root.innerHTML.trim();
            const plainText = quill.getText().trim();

            // Copy the actual HTML to the hidden textarea (this is what gets sent to server)
            contentTextarea.value = htmlContent;

            // Robust empty content check
            const isEmpty = 
                !htmlContent || 
                plainText.length === 0 ||
                htmlContent === '<p><br></p>' || 
                htmlContent === '<p></p>' ||
                htmlContent === '<p>&nbsp;</p>';

            if (isEmpty) {
                e.preventDefault();
                alert('Konten post tidak boleh kosong!');
                return false;
            }
        });
    </script>
</body>
</html>

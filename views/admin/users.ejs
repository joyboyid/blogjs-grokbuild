<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark navbar-modern">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/admin/dashboard">
                <i class="bi bi-speedometer2"></i>
                <span>BlogJS Admin</span>
            </a>
            <div class="d-flex align-items-center gap-2">
                <a href="/" class="btn btn-outline-light btn-sm d-flex align-items-center gap-1" target="_blank">
                    <i class="bi bi-box-arrow-up-right"></i> <span class="d-none d-md-inline">View Site</span>
                </a>
                <a href="/admin/users/create" class="btn btn-primary btn-sm d-flex align-items-center gap-1">
                    <i class="bi bi-person-plus"></i> <span class="d-none d-md-inline">New User</span>
                </a>
                <a href="/auth/logout" class="btn btn-danger btn-sm d-flex align-items-center gap-1">
                    <i class="bi bi-box-arrow-right"></i> <span class="d-none d-md-inline">Logout</span>
                </a>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2 px-0 bg-light border-end min-vh-100">
                <div class="list-group list-group-flush">
                    <a href="/admin/dashboard" class="list-group-item list-group-item-action">📊 Dashboard</a>
                    <a href="/admin/posts" class="list-group-item list-group-item-action">📝 All Posts</a>
                    <a href="/admin/posts/create" class="list-group-item list-group-item-action">+ New Post</a>
                    <a href="/admin/categories" class="list-group-item list-group-item-action">📁 Categories</a>
                    <a href="/admin/categories/create" class="list-group-item list-group-item-action">+ New Category</a>
                    <a href="/admin/users" class="list-group-item list-group-item-action active">👥 All Users</a>
                    <a href="/admin/users/create" class="list-group-item list-group-item-action">+ Create User</a>
                </div>
            </div>

            <div class="col-md-10 p-4">
                <%- include('../partials/flash') %>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2>All Users</h2>
                    <a href="/admin/users/create" class="btn btn-primary">+ Create New User</a>
                </div>

                <% if (users && users.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Created</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% users.forEach(u => { %>
                                    <tr>
                                        <td><%= u.id %></td>
                                        <td class="fw-semibold"><%= u.name %></td>
                                        <td><%= u.email %></td>
                                        <td>
                                            <% if (u.role === 'admin') { %>
                                                <span class="badge bg-primary">Admin</span>
                                            <% } else { %>
                                                <span class="badge bg-success">Author</span>
                                            <% } %>
                                        </td>
                                        <td class="text-muted small">
                                            <%= new Date(u.created_at).toLocaleDateString() %>
                                        </td>
                                        <td class="text-end">
                                            <% if (user && user.id !== u.id) { %>
                                                <form action="/admin/users/<%= u.id %>/delete" method="POST" class="d-inline"
                                                      onsubmit="return confirm('Delete this user? This cannot be undone.')">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                                </form>
                                            <% } else { %>
                                                <span class="text-muted small">—</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="alert alert-info">
                        No users found.
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Admin - BlogJS' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Admin Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/admin/dashboard">BlogJS Admin</a>
            <div class="d-flex align-items-center">
                <span class="text-light small me-3 d-none d-md-block">Logged in as <%= user ? user.name : '' %></span>
                <a href="/" class="btn btn-outline-light btn-sm me-2" target="_blank">View Site</a>
                <a href="/auth/logout" class="btn btn-danger btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-2 col-lg-2 px-0 bg-light border-end min-vh-100">
                <div class="list-group list-group-flush">
                    <a href="/admin/dashboard" class="list-group-item list-group-item-action <%= currentPath === '/admin/dashboard' ? 'active' : '' %>">
                        📊 Dashboard
                    </a>
                    <a href="/admin/posts" class="list-group-item list-group-item-action <%= currentPath.startsWith('/admin/posts') ? 'active' : '' %>">
                        📝 Posts
                    </a>
                    <a href="/admin/posts/create" class="list-group-item list-group-item-action">
                        + New Post
                    </a>
                    <a href="/admin/categories" class="list-group-item list-group-item-action <%= currentPath.startsWith('/admin/categories') ? 'active' : '' %>">
                        📁 Categories
                    </a>
                    <a href="/admin/categories/create" class="list-group-item list-group-item-action">
                        + New Category
                    </a>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-md-10 col-lg-10 p-4">
                <%- include('../partials/flash') %>
                <%- body %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

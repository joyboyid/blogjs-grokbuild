<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Admin - BlogJS' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>
<body>
    <!-- Admin Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark navbar-modern">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/admin/dashboard">
                <i class="bi bi-speedometer2"></i>
                <span><%= (user && user.role === 'author') ? 'Dashboard Author' : 'BlogJS Admin' %></span>
            </a>
            <div class="d-flex align-items-center gap-2">
                <span class="text-light small me-2 d-none d-lg-block opacity-75">Hi, <%= user ? user.name.split(' ')[0] : '' %></span>
                <a href="/" class="btn btn-outline-light btn-sm d-flex align-items-center gap-1" target="_blank">
                    <i class="bi bi-box-arrow-up-right"></i> <span class="d-none d-md-inline">View Site</span>
                </a>
                <a href="/auth/logout" class="btn btn-danger btn-sm d-flex align-items-center gap-1">
                    <i class="bi bi-box-arrow-right"></i> <span class="d-none d-md-inline">Logout</span>
                </a>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-2 col-lg-2 px-0 bg-light border-end min-vh-100">
                <div class="list-group list-group-flush">
                    <a href="/admin/dashboard" class="list-group-item list-group-item-action <%= currentPath === '/admin/dashboard' ? 'active' : '' %>">
                        📊 Dashboard
                    </a>
                    <a href="/admin/posts" class="list-group-item list-group-item-action <%= currentPath.startsWith('/admin/posts') ? 'active' : '' %>">
                        📝 All Posts
                    </a>
                    <a href="/admin/posts/create" class="list-group-item list-group-item-action">
                        + New Post
                    </a>
                    <% if (user && user.role === 'admin') { %>
                        <a href="/admin/categories" class="list-group-item list-group-item-action <%= currentPath.startsWith('/admin/categories') ? 'active' : '' %>">
                            📁 Categories
                        </a>
                        <a href="/admin/categories/create" class="list-group-item list-group-item-action">
                            + New Category
                        </a>
                        <a href="/admin/users" class="list-group-item list-group-item-action <%= currentPath === '/admin/users' ? 'active' : '' %>">
                            👥 All Users
                        </a>
                        <a href="/admin/users/create" class="list-group-item list-group-item-action <%= currentPath === '/admin/users/create' ? 'active' : '' %>">
                            + Create User
                        </a>
                    <% } %>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-md-10 col-lg-10 p-4">
                <%- include('../partials/flash') %>
                <%- body %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark navbar-modern">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/admin/dashboard">
                <i class="bi bi-speedometer2"></i>
                <span><%= (user && user.role === 'author') ? 'Dashboard Author' : 'BlogJS Admin' %></span>
            </a>
            <div class="d-flex align-items-center gap-2">
                <a href="/" class="btn btn-outline-light btn-sm d-flex align-items-center gap-1" target="_blank">
                    <i class="bi bi-box-arrow-up-right"></i> <span class="d-none d-md-inline">View Site</span>
                </a>
                <a href="/auth/logout" class="btn btn-danger btn-sm d-flex align-items-center gap-1">
                    <i class="bi bi-box-arrow-right"></i> <span class="d-none d-md-inline">Logout</span>
                </a>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-2 px-0 bg-light border-end min-vh-100">
                <div class="list-group list-group-flush">
                    <a href="/admin/dashboard" class="list-group-item list-group-item-action">📊 Dashboard</a>
                    <a href="/admin/posts" class="list-group-item list-group-item-action">📝 All Posts</a>
                    <a href="/admin/posts/create" class="list-group-item list-group-item-action">+ New Post</a>
                    <a href="/admin/categories" class="list-group-item list-group-item-action">📁 Categories</a>
                    <a href="/admin/categories/create" class="list-group-item list-group-item-action">+ New Category</a>
                    <a href="/admin/users" class="list-group-item list-group-item-action">👥 All Users</a>
                    <a href="/admin/users/create" class="list-group-item list-group-item-action active">+ Create User</a>
                </div>
            </div>

            <div class="col-md-10 p-4">
                <%- include('../partials/flash') %>

                <div class="d-flex justify-content-between mb-4">
                    <h2>Create New User</h2>
                    <a href="/admin/dashboard" class="btn btn-outline-secondary">← Back to Dashboard</a>
                </div>

                <div class="row">
                    <div class="col-lg-6">
                        <div class="card shadow-sm">
                            <div class="card-body">
                                <% if (errors && errors.length > 0) { %>
                                    <div class="alert alert-danger">
                                        <% errors.forEach(e => { %><p class="mb-1"><%= e.msg %></p><% }) %>
                                    </div>
                                <% } %>

                                <form action="/admin/users/create" method="POST">
                                    <div class="mb-3">
                                        <label class="form-label">Full Name *</label>
                                        <input type="text" name="name" class="form-control" 
                                               value="<%= oldInput.name || '' %>" required>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Email Address *</label>
                                        <input type="email" name="email" class="form-control" 
                                               value="<%= oldInput.email || '' %>" required>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Role *</label>
                                        <select name="role" class="form-select" required>
                                            <option value="author" <%= (oldInput.role === 'author') ? 'selected' : '' %>>
                                                Author (can only manage posts)
                                            </option>
                                            <option value="admin" <%= (!oldInput.role || oldInput.role === 'admin') ? 'selected' : '' %>>
                                                Admin (full access)
                                            </option>
                                        </select>
                                        <div class="form-text">Authors can only create/edit/delete posts. Admins have full access including categories and user management.</div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Password *</label>
                                            <input type="password" name="password" class="form-control" required minlength="6">
                                            <div class="form-text">Minimum 6 characters</div>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Confirm Password *</label>
                                            <input type="password" name="confirmPassword" class="form-control" required>
                                        </div>
                                    </div>

                                    <div class="d-flex gap-2 mt-3">
                                        <button type="submit" class="btn btn-primary">
                                            <i class="bi bi-person-plus me-1"></i> Create User
                                        </button>
                                        <a href="/admin/dashboard" class="btn btn-light">Cancel</a>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <div class="alert alert-info mt-4 small">
                            <strong>Note:</strong> 
                            <strong>Author</strong> = can only create, edit and delete posts.<br>
                            <strong>Admin</strong> = full access (posts, categories, and user management).
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

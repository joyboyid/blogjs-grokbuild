<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark navbar-modern">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/admin/dashboard">
                <i class="bi bi-speedometer2"></i>
                <span><%= (user && user.role === 'author') ? 'Dashboard Author' : 'BlogJS Admin' %></span>
            </a>
            <div class="d-flex align-items-center gap-2">
                <span class="text-light small me-2 d-none d-lg-block opacity-75">Hi, <%= user ? user.name.split(' ')[0] : '' %></span>
                <a href="/" class="btn btn-outline-light btn-sm d-flex align-items-center gap-1" target="_blank">
                    <i class="bi bi-box-arrow-up-right"></i> <span class="d-none d-md-inline">View Site</span>
                </a>
                <a href="/auth/logout" class="btn btn-danger btn-sm d-flex align-items-center gap-1">
                    <i class="bi bi-box-arrow-right"></i> <span class="d-none d-md-inline">Logout</span>
                </a>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <div class="col-md-2 col-lg-2 px-0 bg-light border-end min-vh-100">
                <div class="list-group list-group-flush">
                    <a href="/admin/dashboard" class="list-group-item list-group-item-action active">📊 Dashboard</a>
                    <% if (userRole === 'admin') { %>
                        <a href="/admin/posts" class="list-group-item list-group-item-action">📝 All Posts</a>
                    <% } else { %>
                        <a href="/admin/myposts" class="list-group-item list-group-item-action">📝 My Posts</a>
                    <% } %>
                    <a href="/admin/posts/create" class="list-group-item list-group-item-action">+ New Post</a>
                    <% if (userRole === 'admin') { %>
                        <a href="/admin/categories" class="list-group-item list-group-item-action">📁 Categories</a>
                        <a href="/admin/categories/create" class="list-group-item list-group-item-action">+ New Category</a>
                        <a href="/admin/users" class="list-group-item list-group-item-action">👥 All Users</a>
                        <a href="/admin/users/create" class="list-group-item list-group-item-action">+ Create User</a>
                    <% } %>
                </div>
            </div>

            <div class="col-md-10 col-lg-10 p-4">
                <%- include('../partials/flash') %>

                <h2 class="mb-4">Dashboard</h2>

                <div class="row g-4 mb-5">
                    <div class="col-md-4">
                        <div class="card shadow-sm">
                            <div class="card-body">
                                <h6 class="text-muted">Total Posts</h6>
                                <h2 class="display-6 mb-0"><%= stats.totalPosts %></h2>
                            </div>
                        </div>
                    </div>
                    <% if (userRole === 'admin') { %>
                    <div class="col-md-4">
                        <div class="card shadow-sm">
                            <div class="card-body">
                                <h6 class="text-muted">Categories</h6>
                                <h2 class="display-6 mb-0"><%= stats.totalCategories %></h2>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card shadow-sm">
                            <div class="card-body">
                                <h6 class="text-muted">Quick Actions</h6>
                                <a href="/admin/posts/create" class="btn btn-sm btn-primary">New Post</a>
                                <a href="/admin/categories/create" class="btn btn-sm btn-outline-secondary">New Category</a>
                                <a href="/admin/users/create" class="btn btn-sm btn-outline-primary ms-1">New User</a>
                            </div>
                        </div>
                    </div>
                    <% } else { %>
                    <div class="col-md-4">
                        <div class="card shadow-sm">
                            <div class="card-body">
                                <h6 class="text-muted">Quick Actions</h6>
                                <a href="/admin/posts/create" class="btn btn-sm btn-primary">New Post</a>
                                <a href="/admin/myposts" class="btn btn-sm btn-outline-secondary">My Posts</a>
                            </div>
                        </div>
                    </div>
                    <% } %>
                </div>

                <h5 class="mb-3">Recent Posts</h5>
                <% if (stats.recentPosts && stats.recentPosts.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Created by</th>
                                    <th>Category</th>
                                    <th>Date</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <% stats.recentPosts.forEach(p => { %>
                                    <tr>
                                        <td><a href="/post/<%= p.slug %>" target="_blank"><%= p.title %></a></td>
                                        <td><span class="badge bg-light text-dark"><%= p.author_name || 'Unknown' %></span></td>
                                        <td><span class="badge bg-light text-dark"><%= p.category_name || 'Uncategorized' %></span></td>
                                        <td class="text-muted small"><%= new Date(p.created_at).toLocaleDateString() %></td>
                                        <td class="text-end">
                                            <a href="/admin/posts/<%= p.id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <p class="text-muted">No posts yet. <a href="/admin/posts/create">Create your first post</a>.</p>
                <% } %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

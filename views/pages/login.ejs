<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <!-- Modern minimal top nav -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark navbar-modern">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
                <i class="bi bi-journal-text"></i>
                <span>BlogJS</span>
            </a>
            <div class="d-flex align-items-center gap-2">
                <a class="nav-link text-light px-2" href="/about"><i class="bi bi-info-circle me-1"></i>About</a>
                <a class="nav-link text-light px-2" href="/contact"><i class="bi bi-envelope me-1"></i>Contact</a>

                <% if (user) { %>
                    <a href="/admin/dashboard" class="btn btn-primary btn-sm d-flex align-items-center gap-1">
                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard</span>
                    </a>
                <% } else { %>
                    <a class="btn btn-primary btn-sm d-flex align-items-center gap-1" href="/auth/register">
                        <i class="bi bi-person-plus"></i>
                        <span>Get Started</span>
                    </a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="row justify-content-center mt-5">
            <div class="col-md-5">
                <div class="card shadow">
                    <div class="card-body p-4">
                        <h3 class="text-center mb-4">Login to BlogJS</h3>

                        <%- include('../partials/flash') %>

                        <% if (errors && errors.length > 0) { %>
                            <div class="alert alert-danger">
                                <% errors.forEach(e => { %><p class="mb-1"><%= e.msg %></p><% }) %>
                            </div>
                        <% } %>

                        <form action="/auth/login" method="POST">
                            <div class="mb-3">
                                <label class="form-label">Email address</label>
                                <input type="email" name="email" class="form-control" 
                                       value="<%= oldInput.email || '' %>" required autofocus>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <input type="password" name="password" class="form-control" required>
                            </div>
                            <button type="submit" class="btn btn-primary w-100 py-2">Login</button>
                        </form>

                        <div class="text-center mt-3">
                            <small class="text-muted">Registration is disabled. Contact an administrator to create an account.</small>
                        </div>
                    </div>
                </div>
                
                <p class="text-center text-muted mt-3 small">
                    Default admin: <strong>admin@blogjs.local</strong> / <strong>admin123</strong><br>
                    <small>(Change password after first login. New admins must be created by existing admins.)</small>
                </p>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

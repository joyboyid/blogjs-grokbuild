<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
    <!-- Minimal top nav for auth pages -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">BlogJS</a>
            <div class="d-flex">
                <a class="nav-link text-light me-3" href="/about">About</a>
                <a class="nav-link text-light me-3" href="/contact">Contact Us</a>
                <a class="btn btn-outline-light btn-sm" href="/auth/register">Register</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="row justify-content-center mt-5">
            <div class="col-md-5">
                <div class="card shadow">
                    <div class="card-body p-4">
                        <h3 class="text-center mb-4">Login to BlogJS</h3>

                        <%- include('../partials/flash') %>

                        <% if (errors && errors.length > 0) { %>
                            <div class="alert alert-danger">
                                <% errors.forEach(e => { %><p class="mb-1"><%= e.msg %></p><% }) %>
                            </div>
                        <% } %>

                        <form action="/auth/login" method="POST">
                            <div class="mb-3">
                                <label class="form-label">Email address</label>
                                <input type="email" name="email" class="form-control" 
                                       value="<%= oldInput.email || '' %>" required autofocus>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <input type="password" name="password" class="form-control" required>
                            </div>
                            <button type="submit" class="btn btn-primary w-100 py-2">Login</button>
                        </form>

                        <div class="text-center mt-3">
                            <small>Don't have an account? <a href="/auth/register">Register here</a></small>
                        </div>
                    </div>
                </div>
                
                <p class="text-center text-muted mt-3 small">
                    Default: admin@blogjs.local / admin123 (change after first login)
                </p>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

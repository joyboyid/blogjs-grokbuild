<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <!-- Modern top nav -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark navbar-modern">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
                <i class="bi bi-journal-text"></i>
                <span>BlogJS</span>
            </a>
            <div class="d-flex gap-3 align-items-center">
                <a class="nav-link text-light px-2" href="/about"><i class="bi bi-info-circle me-1"></i>About</a>
                <a class="nav-link text-light px-2" href="/contact"><i class="bi bi-envelope me-1"></i>Contact</a>

                <% if (user) { %>
                    <a href="/admin/dashboard" class="btn btn-primary btn-sm d-flex align-items-center gap-1">
                        <i class="bi bi-speedometer2"></i>
                        <span class="d-none d-md-inline">Dashboard</span>
                    </a>
                <% } else { %>
                    <a class="nav-link text-light px-2" href="/auth/login">Login</a>
                    <a class="btn btn-primary btn-sm d-flex align-items-center gap-1" href="/auth/register">
                        <i class="bi bi-person-plus"></i>
                        <span>Get Started</span>
                    </a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container text-center mt-5">
        <div style="padding-top: 60px;">
        <h1 class="display-4 text-danger">Oops!</h1>
        <h3 class="mb-3">Something went wrong</h3>
        <p class="text-muted"><%= message %></p>
        
        <% if (process.env.NODE_ENV === 'development' && error) { %>
            <pre class="text-start bg-white p-3 rounded border text-danger small" style="max-height: 300px; overflow:auto;">
                <%= error.stack || error %>
            </pre>
        <% } %>
        
        <a href="/" class="btn btn-primary mt-3">Back to Home</a>
        </div>
    </div>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= metaDescription %>">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <main class="container py-4">
        <%- include('../partials/flash') %>

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <!-- Breadcrumb / Back -->
                <nav aria-label="breadcrumb" class="mb-3">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Home</a></li>
                        <% if (post.category_name) { %>
                            <li class="breadcrumb-item">
                                <a href="/category/<%= post.category_slug %>"><%= post.category_name %></a>
                            </li>
                        <% } %>
                        <li class="breadcrumb-item active" aria-current="page">Article</li>
                    </ol>
                </nav>

                <article>
                    <% if (post.featured_image) { %>
                        <img src="<%= post.featured_image %>" 
                             class="img-fluid rounded mb-4 shadow-sm" 
                             alt="<%= post.title %>"
                             style="max-height: 420px; width: 100%; object-fit: cover;">
                    <% } %>

                    <h1 class="display-6 fw-bold mb-3"><%= post.title %></h1>

                    <div class="d-flex align-items-center text-muted mb-4">
                        <span>
                            <%= new Date(post.created_at).toLocaleDateString('en-US', { 
                                weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' 
                            }) %>
                        </span>
                        
                        <% if (post.category_name) { %>
                            <span class="mx-2">•</span>
                            <a href="/category/<%= post.category_slug %>" class="badge bg-primary text-decoration-none">
                                <%= post.category_name %>
                            </a>
                        <% } %>
                        
                        <% if (post.tags) { %>
                            <span class="mx-2">•</span>
                            <% post.tags.split(',').forEach(tag => { %>
                                <span class="badge bg-light text-dark me-1">#<%= tag.trim() %></span>
                            <% }) %>
                        <% } %>
                    </div>

                    <!-- Rich HTML Content from Quill.js editor -->
                    <div class="post-content lead">
                        <%- post.content %>
                    </div>
                </article>

                <hr class="my-5">

                <div class="d-flex justify-content-between">
                    <a href="/" class="btn btn-outline-secondary">← Back to Home</a>
                    
                    <% if (user && user.role === 'admin') { %>
                        <div>
                            <a href="/admin/posts/<%= post.id %>/edit" class="btn btn-outline-primary">Edit Post</a>
                            <form action="/admin/posts/<%= post.id %>/delete" method="POST" class="d-inline" 
                                  onsubmit="return confirm('Delete this post permanently?')">
                                <button type="submit" class="btn btn-outline-danger">Delete</button>
                            </form>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Learn more about BlogJS - a modern blog platform built with Node.js, Express, MariaDB, and Bootstrap.">
    <title>About Us - BlogJS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <!-- Bootstrap Icons for modern navbar -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <main class="container py-5">
        <%- include('../partials/flash') %>

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <!-- Hero -->
                <div class="text-center mb-5">
                    <h1 class="display-5 fw-bold">About BlogJS</h1>
                    <p class="lead text-muted">A clean, simple, and modern blogging platform.</p>
                </div>

                <div class="card shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h2 class="h4 mb-3">What is BlogJS?</h2>
                        <p>
                            BlogJS is a lightweight yet complete blog application built as a demonstration of modern 
                            web development practices using <strong>Node.js + Express.js</strong>.
                        </p>
                        <p>
                            It was created to showcase a full-featured blog system with user authentication, 
                            rich text editing, image uploads, categories, and a responsive design — all powered 
                            by MariaDB.
                        </p>
                    </div>
                </div>

                <div class="card shadow-sm mb-4">
                    <div class="card-body p-4">
                        <h2 class="h4 mb-3">Technology Stack</h2>
                        <div class="row">
                            <div class="col-md-6">
                                <ul class="list-unstyled">
                                    <li class="mb-2">✅ <strong>Backend:</strong> Node.js + Express.js</li>
                                    <li class="mb-2">✅ <strong>Database:</strong> MariaDB (mysql2 with Promises)</li>
                                    <li class="mb-2">✅ <strong>Templating:</strong> EJS</li>
                                    <li class="mb-2">✅ <strong>Authentication:</strong> express-session + bcryptjs</li>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <ul class="list-unstyled">
                                    <li class="mb-2">✅ <strong>Rich Editor:</strong> Quill.js (free &amp; open)</li>
                                    <li class="mb-2">✅ <strong>UI:</strong> Bootstrap 5 (fully responsive)</li>
                                    <li class="mb-2">✅ <strong>Validation:</strong> express-validator</li>
                                    <li class="mb-2">✅ <strong>File Upload:</strong> Multer</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <h2 class="h4 mb-3">Our Mission</h2>
                        <p class="mb-0">
                            To provide a simple, beautiful, and educational blogging platform that developers 
                            can learn from, extend, and use as a foundation for their own projects.
                        </p>
                    </div>
                </div>

                <div class="text-center mt-5">
                    <a href="/" class="btn btn-outline-primary me-2">← Back to Home</a>
                    <a href="/contact" class="btn btn-primary">Contact Us</a>
                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

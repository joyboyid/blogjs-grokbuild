<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Get in touch with the BlogJS team. Send us your questions, feedback, or suggestions.">
    <title>Contact Us - BlogJS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <main class="container py-5">
        <%- include('../partials/flash') %>

        <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
            <div class="row justify-content-center mb-3">
                <div class="col-lg-7">
                    <div class="alert alert-danger">
                        <% errors.forEach(e => { %>
                            <div><%= e.msg %></div>
                        <% }) %>
                    </div>
                </div>
            </div>
        <% } %>

        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="text-center mb-4">
                    <h1 class="display-6 fw-bold">Contact Us</h1>
                    <p class="text-muted">Have a question, feedback, or want to collaborate? We'd love to hear from you.</p>
                </div>

                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <form action="/contact" method="POST">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Your Name</label>
                                    <input type="text" name="name" class="form-control" 
                                           value="<%= typeof oldInput !== 'undefined' ? oldInput.name || '' : '' %>" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Email Address</label>
                                    <input type="email" name="email" class="form-control" 
                                           value="<%= typeof oldInput !== 'undefined' ? oldInput.email || '' : '' %>" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Subject</label>
                                <input type="text" name="subject" class="form-control" 
                                       value="<%= typeof oldInput !== 'undefined' ? oldInput.subject || '' : '' %>"
                                       placeholder="General inquiry, bug report, feature request..." required>
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Message</label>
                                <textarea name="message" class="form-control" rows="6" required 
                                    placeholder="Tell us more about your message..."><%= typeof oldInput !== 'undefined' ? oldInput.message || '' : '' %></textarea>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-lg">Send Message</button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="text-center mt-4 text-muted small">
                    <p>We typically respond within 1-2 business days.</p>
                    <p>Alternatively, you can reach us at <a href="mailto:hello@blogjs.local">hello@blogjs.local</a></p>
                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
